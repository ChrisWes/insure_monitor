# Companies House API key
# Obtain a free key from: https://developer.company-information.service.gov.uk/
CH_API_KEY=your_companies_house_api_key_here

# Adzuna API (job_monitor.py)
# Obtain from: https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# NewsAPI (intelligence_monitor.py)
# Obtain from: https://newsapi.org/
NEWS_API_KEY=your_newsapi_key_here

# Anthropic API — Claude LLM commentary (intelligence_monitor.py)
# Obtain from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Email delivery (officer_monitor.py)
# Leave SMTP_HOST blank to disable email entirely
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=sender@example.com
EMAIL_TO=recipient@example.com,another@example.com
